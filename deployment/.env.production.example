APP_ENV=production
APP_VERSION=0.3.0
ENABLE_API_DOCS=false
SECRET_KEY=
ACCESS_TOKEN_MINUTES=30
REFRESH_TOKEN_DAYS=14
REFRESH_COOKIE_NAME=xueji_refresh
COOKIE_DOMAIN=
COOKIE_SAMESITE=lax

POSTGRES_DB=xueji_zhice
POSTGRES_USER=xueji_app
POSTGRES_PASSWORD=
DATABASE_URL=postgresql+psycopg://xueji_app:REPLACE_AT_DEPLOYMENT@postgres:5432/xueji_zhice
REDIS_URL=redis://redis:6379/0
CORS_ORIGINS=https://www.example.com
FRONTEND_PUBLIC_URL=https://www.example.com
MAX_UPLOAD_MB=10
HTTP_PORT=80

STORAGE_PROVIDER=s3
FILE_STORAGE_PATH=/data/uploads
STORAGE_BUCKET=
STORAGE_ENDPOINT_URL=
STORAGE_REGION=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_PRESIGN_SECONDS=300

REQUIRE_EMAIL_VERIFICATION=true
EMAIL_PROVIDER=smtp
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_STARTTLS=true
EMAIL_VERIFICATION_HOURS=24
PASSWORD_RESET_MINUTES=30

ENABLE_DEMO=false
SEED_DEMO_DATA=false
AUTO_CREATE_SCHEMA=false

OCR_ENABLED=true
OCR_PROVIDER=paddle_http
OCR_SERVICE_URL=
OCR_SERVICE_TOKEN=
OCR_TIMEOUT_SECONDS=60
OCR_QUEUE_NAME=xueji:ocr:jobs
OCR_MAX_ATTEMPTS=3

AI_ENABLED=true
AI_PRIMARY_PROVIDER=bailian_openai
AI_FALLBACK_PROVIDER=hunyuan_openai
AI_QUEUE_NAME=xueji:ai:reports
AI_TIMEOUT_SECONDS=90
AI_MAX_ATTEMPTS=2
AI_PROMPT_VERSION=learning-report-v1
AI_MAX_INPUT_CHARS=30000
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_API_KEY=
BAILIAN_MODEL=qwen-plus
HUNYUAN_BASE_URL=https://api.hunyuan.cloud.tencent.com/v1
HUNYUAN_API_KEY=
HUNYUAN_MODEL=hunyuan-turbos-latest
