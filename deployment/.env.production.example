APP_ENV=production
APP_VERSION=0.3.0
ENABLE_API_DOCS=false
SECRET_KEY=
ACCESS_TOKEN_MINUTES=30
REFRESH_TOKEN_DAYS=14
REFRESH_COOKIE_NAME=xueji_refresh
COOKIE_DOMAIN=www.example.com
COOKIE_SAMESITE=lax

POSTGRES_DB=xueji_zhice
POSTGRES_USER=xueji_app
POSTGRES_PASSWORD=
DATABASE_URL=postgresql+psycopg://xueji_app:CHANGE_ME@postgres:5432/xueji_zhice
REDIS_URL=redis://redis:6379/0
CORS_ORIGINS=https://www.example.com
MAX_UPLOAD_MB=10
HTTP_PORT=80

STORAGE_PROVIDER=s3
FILE_STORAGE_PATH=/data/uploads
STORAGE_BUCKET=
STORAGE_ENDPOINT_URL=
STORAGE_REGION=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_PRESIGN_SECONDS=300

ENABLE_DEMO=false
SEED_DEMO_DATA=false
AUTO_CREATE_SCHEMA=false

# v0.3.0未交付真实OCR/AI适配器，必须关闭，界面不会显示伪AI评价。
OCR_ENABLED=false
AI_ENABLED=false
OCR_PROVIDER=disabled
AI_PRIMARY_PROVIDER=disabled
AI_FALLBACK_PROVIDER=disabled
DASHSCOPE_API_KEY=
BAILIAN_MODEL=qwen-plus
HUNYUAN_SECRET_ID=
HUNYUAN_SECRET_KEY=
HUNYUAN_MODEL=hunyuan-turbos-latest
