APP_ENV=development
SECRET_KEY=replace-with-a-long-random-value

POSTGRES_DB=xueji_zhice
POSTGRES_USER=xueji
POSTGRES_PASSWORD=replace-with-a-strong-password
DATABASE_URL=postgresql+psycopg://xueji:replace-with-a-strong-password@postgres:5432/xueji_zhice
