APP_ENV=development
APP_VERSION=0.3.0
ENABLE_API_DOCS=true
SECRET_KEY=local-development-secret-change-before-production
ACCESS_TOKEN_MINUTES=30
REFRESH_TOKEN_DAYS=14
REFRESH_COOKIE_NAME=xueji_refresh
COOKIE_DOMAIN=
COOKIE_SAMESITE=lax

POSTGRES_DB=xueji_zhice
POSTGRES_USER=xueji
POSTGRES_PASSWORD=local-dev-password
DATABASE_URL=postgresql+psycopg://xueji:local-dev-password@postgres:5432/xueji_zhice
REDIS_URL=redis://redis:6379/0

CORS_ORIGINS=http://localhost:5173,http://localhost
MAX_UPLOAD_MB=10
HTTP_PORT=80

STORAGE_PROVIDER=local
FILE_STORAGE_PATH=/data/uploads
STORAGE_BUCKET=
STORAGE_ENDPOINT_URL=
STORAGE_REGION=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_PRESIGN_SECONDS=300

# 仅开发环境允许。生产环境启动时会强制拒绝。
ENABLE_DEMO=true
SEED_DEMO_DATA=true
AUTO_CREATE_SCHEMA=false

# v0.3.0未交付真实OCR/AI适配器，生产环境必须保持false。
OCR_ENABLED=false
AI_ENABLED=false
OCR_PROVIDER=disabled
AI_PRIMARY_PROVIDER=disabled
AI_FALLBACK_PROVIDER=disabled
DASHSCOPE_API_KEY=
BAILIAN_MODEL=qwen-plus
HUNYUAN_SECRET_ID=
HUNYUAN_SECRET_KEY=
HUNYUAN_MODEL=hunyuan-turbos-latest
